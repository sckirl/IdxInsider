graph TD
    %% Global Styles
    classDef supervisor fill:#6a1b9a,stroke:#4a148c,color:#fff,stroke-width:4px;
    classDef pm fill:#fbc02d,stroke:#f57f17,color:#000,font-weight:bold;
    classDef ba fill:#0277bd,stroke:#01579b,color:#fff;
    classDef dev fill:#2e7d32,stroke:#1b5e20,color:#fff;
    classDef qa fill:#c62828,stroke:#b71c1c,color:#fff;
    classDef infrastructure fill:#37474f,stroke:#263238,color:#fff,stroke-dasharray: 5 5;
    classDef external fill:#4527a0,stroke:#311b92,color:#fff;

    subgraph User_Interface [External Interaction & Network]
        User((User/Owner))
        Tailscale[Tailscale IP / Remote Access]:::infrastructure
        ProdURL[Next.js UI :6969]
        Stockbit[Stockbit Insider Verification]:::external
    end

    subgraph Control_Plane [Command & Control]
        Supervisor[Gemini CLI / Senior Architect]:::supervisor
        PM[Project Manager Agent]:::pm
    end

    subgraph Intelligence_Layer [Data & Logic Design]
        BA[Business Analyst Agent]:::ba
        Scoring[Smart Scoring & Cluster Logic]
    end

    subgraph Execution_Core [Engineering & Automation]
        DEV[Developer Agent]:::dev
        API[FastAPI Backend :8000]
        Scraper[Multi-threaded Scraper]
        Scheduler[Randomized Scheduler 1AM-5AM]:::infrastructure
    end

    subgraph Data_Layer [Source & Storage]
        IDX_API[(IDX 2026 API / PDF)]
        DB[(PostgreSQL)]
    end

    subgraph Validation_Layer [Quality & Resilience]
        QA[QA Engineer Agent]:::qa
    end

    %% Workflow Flow
    User -->|Access via| Tailscale
    Tailscale -->|Browser Execution| ProdURL
    ProdURL -->|Verify Transactions| Stockbit
    
    User -->|Directives| Supervisor
    Supervisor -->|Plan Mode| PM
    PM -->|Features| BA
    BA -->|Data Logic| Scoring
    Scoring -->|Schema| DEV
    DEV -->|Implement| API
    DEV -->|Optimize| Scraper
    Scraper -->|Ingest| IDX_API
    Scraper -->|Store| DB
    API <-->|Serve| DB
    
    Scheduler -->|Trigger| Scraper
    
    %% QA Loop
    QA -->|Connectivity Tests| Tailscale
    QA -->|Data Accuracy| DB
    QA -->|UAT Reports| Supervisor

    %% Connectivity
    ProdURL <-->|NEXT_PUBLIC_API_URL| API

    %% Agent Duties
    subgraph Agent_Specialization [Finalized Duties]
        direction LR
        PM_D[Roadmap / UX / Approval]:::pm
        BA_D[Ticker Expansion / NLP]:::ba
        DEV_D[Docker / Playwright / FastAPI]:::dev
        QA_D[Regression / UAT / Network]:::qa
    end
